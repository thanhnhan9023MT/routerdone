# RouterDone — Dokploy Environment template.
# Paste these into Dokploy > Environment. Replace placeholder values.
# Do not commit a real .env file with production secrets.

JWT_SECRET=replace-with-openssl-rand-hex-32
INITIAL_PASSWORD=replace-with-a-long-admin-password
DATA_DIR=/app/data

PORT=20128
HOSTNAME=0.0.0.0
NODE_ENV=production
TZ=Asia/Saigon
NEXT_TELEMETRY_DISABLED=1

# Public URL served by Dokploy. Keep both server and public values aligned.
BASE_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com

API_KEY_SECRET=replace-with-openssl-rand-hex-32
MACHINE_ID_SALT=replace-with-openssl-rand-hex-32
AUTH_COOKIE_SECURE=true

# For customer-facing API service, keep this true.
REQUIRE_API_KEY=true

ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true

# Optional: only set these if you use Gemini or Antigravity OAuth providers.
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=